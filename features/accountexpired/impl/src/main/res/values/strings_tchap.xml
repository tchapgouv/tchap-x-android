<resources>
    <string name="tchap_screen_account_expired_title">"Your account has expired"</string>
    <string name="tchap_screen_account_expired_description">"An email has been sent to you to renew your account. Once you have followed the link in it, click below."</string>
    <string name="tchap_screen_account_expired_button_send_email">"Send a new email"</string>
    <string name="tchap_screen_account_expired_send_email_success_title">"New email sent."</string>
    <string name="tchap_screen_account_expired_send_email_success_message">"A new email has been sent to you to \"Renew your account\". Once you have followed the link in the email, click the \"Continue\" button."</string>
    <string name="tchap_screen_account_expired_send_email_error_title">"Unable to send email"</string>
    <string name="tchap_screen_account_expired_send_email_error_message">"An error occurred. Please try again later or contact support if the problem persists."</string>
    <string name="tchap_screen_account_expired_start_sync_error_title">"Account still locked"</string>
    <string name="tchap_screen_account_expired_start_sync_error_message">"Make sure you clicked the link in the email, or request a new email."</string>
</resources>
